# Supabase — copia este archivo a .env.local y rellena con tus credenciales.
# Project Settings → API en el dashboard de Supabase.

NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key

# Solo para operaciones privilegiadas del lado servidor (Route Handlers).
# NUNCA la expongas en el cliente ni con prefijo NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# Token secreto para POST /api/channels/[id]/sync (lo usa n8n en el header
# Authorization: Bearer <SYNC_TOKEN>). Genera uno largo y aleatorio.
# NUNCA con prefijo NEXT_PUBLIC_.
SYNC_TOKEN=genera_un_token_largo_y_aleatorio

# Secreto compartido PMS ↔ n8n para el gateway de sync (header x-mf-secret en
# POST /api/sync/callback). NUNCA con prefijo NEXT_PUBLIC_.
MF_SECRET=genera_un_token_largo_y_aleatorio
